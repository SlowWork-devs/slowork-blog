---
// src/components/Footer.astro
const { language = 'es' } = Astro.props;
const currentYear = new Date().getFullYear();

// Diccionario de traducciones para el Footer
const translations = {
	es: {
		rights: 'Todos los derechos reservados.',
		privacy: 'Política de Privacidad',
		contact: 'Contacto',
		cookies: 'Política de Cookies',
		legal: 'Aviso Legal',
		terms: 'Términos y Condiciones',
	},
	en: {
		rights: 'All rights reserved.',
		privacy: 'Privacy Policy',
		contact: 'Contact',
		cookies: 'Cookies Policy',
		legal: 'Legal Notice',
		terms: 'Terms & Conditions',
	}
};

const t = translations[language as 'es' | 'en'] || translations.es;

// Helper para generar links con idioma (evitamos duplicar lógica)
const langPath = (path: string) => `/${language}${path}`;
const contactHref = `${langPath('/')}#contact`;
---

<footer class="bg-primary text-white/90 py-8 font-body w-full mt-auto">
	<div class="max-w-7xl mx-auto px-6">
		<div class="flex flex-col items-center justify-center text-center">
			
			<div class="text-xs sm:text-sm md:text-base leading-loose">
				<span>© {currentYear} Slowork. {t.rights}</span>
				
				<span class="mx-2 text-secondary/90 hidden sm:inline">|</span>
				
				<div class="flex flex-wrap justify-center gap-1 sm:inline-block">
					<a href={langPath('/privacy-policy/')} class="inline-flex items-center justify-center min-h-11 min-w-11 py-2 px-1 hover:text-secondary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded-sm touch-manipulation">{t.privacy}</a>
					<span class="mx-1 hidden sm:inline">|</span>
					
					<a
						href={contactHref}
						class="inline-flex items-center justify-center min-h-11 min-w-11 py-2 px-1 hover:text-secondary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded-sm touch-manipulation"
					>
						{t.contact}
					</a>
					
					<span class="mx-1 hidden sm:inline">|</span>
					<a href={langPath('/cookies-policy/')} class="inline-flex items-center justify-center min-h-11 min-w-11 py-2 px-1 hover:text-secondary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded-sm touch-manipulation">{t.cookies}</a>
					<span class="mx-1 hidden sm:inline">|</span>
					<a href={langPath('/legal-notice/')} class="inline-flex items-center justify-center min-h-11 min-w-11 py-2 px-1 hover:text-secondary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded-sm touch-manipulation">{t.legal}</a>
					<span class="mx-1 hidden sm:inline">|</span>
					<a href={langPath('/terms-and-conditions/')} class="inline-flex items-center justify-center min-h-11 min-w-11 py-2 px-1 hover:text-secondary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded-sm touch-manipulation">{t.terms}</a>
				</div>
			</div>

		</div>
	</div>
</footer>