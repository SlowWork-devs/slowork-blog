---
// src/components/Footer.astro
import { homeFooterCopy } from '@/lib/homeContent';
import { isSupportedLang, type SupportedLang } from '@/lib/seo';

const { language = 'es' } = Astro.props;
const currentYear = new Date().getFullYear();

const lang: SupportedLang = isSupportedLang(language) ? language : 'es';
const t = homeFooterCopy(lang);

const langPath = (path: string) => `/${lang}${path}`;
const contactHref = `${langPath('/')}#contact`;
---

<footer class="bg-primary text-bg-landing/92 py-8 font-body w-full mt-auto">
	<div class="max-w-7xl mx-auto px-6">
		<div class="flex flex-col items-center justify-center text-center">
			
			<div class="text-xs sm:text-sm md:text-base leading-loose">
				<span>© {currentYear} Slowork. {t.rights}</span>
				
				<span class="mx-2 text-secondary/90 hidden sm:inline">|</span>
				
				<div class="flex flex-wrap justify-center gap-1 sm:inline-block" aria-label={t.legalLinksAriaLabel}>
					<a href={langPath(t.routes.privacy)} class="inline-flex items-center justify-center min-h-11 min-w-11 py-2 px-1 hover:text-secondary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded-sm touch-manipulation">{t.privacy}</a>
					<span class="mx-1 hidden sm:inline">|</span>
					
					<a
						href={contactHref}
						class="inline-flex items-center justify-center min-h-11 min-w-11 py-2 px-1 hover:text-secondary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded-sm touch-manipulation"
					>
						{t.contact}
					</a>
					
					<span class="mx-1 hidden sm:inline">|</span>
					<a href={langPath(t.routes.cookies)} class="inline-flex items-center justify-center min-h-11 min-w-11 py-2 px-1 hover:text-secondary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded-sm touch-manipulation">{t.cookies}</a>
					<span class="mx-1 hidden sm:inline">|</span>
					<a href={langPath(t.routes.legalNotice)} class="inline-flex items-center justify-center min-h-11 min-w-11 py-2 px-1 hover:text-secondary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded-sm touch-manipulation">{t.legal}</a>
					<span class="mx-1 hidden sm:inline">|</span>
					<a href={langPath(t.routes.terms)} class="inline-flex items-center justify-center min-h-11 min-w-11 py-2 px-1 hover:text-secondary transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded-sm touch-manipulation">{t.terms}</a>
				</div>
			</div>

		</div>
	</div>
</footer>