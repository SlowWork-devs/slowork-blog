---
import { Image } from 'astro:assets';
import type { LocalizedBlogPost, ApiLang } from '@/lib/api-service';
import { formatBlogCreationDate, stripH1TagsFromHtml, estimateReadingTime } from '@/lib/blog-display';
import { BLOG_IMAGE_CLOUDFRONT_HOST, SITE_TITLE } from '@/consts';

interface Props {
  post: LocalizedBlogPost;
  lang: ApiLang;
  /** Solo el primer ítem del listado (p. ej. `/blog/`): prioriza LCP. */
  imageLcpPriority?: boolean;
}

const { post, lang, imageLcpPriority = false } = Astro.props;
const postUrl = `/${lang}/blog/${post.slug}/`;
const cta = lang === 'es' ? 'Leer más' : 'Read more';
const titleTrimmed = post.title?.trim() ?? '';
const cardTitle = titleTrimmed !== '' ? titleTrimmed : SITE_TITLE;

const cloudFrontImage =
  post.image_url && /^https?:\/\//i.test(post.image_url)
    ? (() => {
        try {
          return new URL(post.image_url).hostname === BLOG_IMAGE_CLOUDFRONT_HOST ? post.image_url : null;
        } catch {
          return null;
        }
      })()
    : null;

const displayDate = post.date_published || post.creation_date;
const formattedDate = formatBlogCreationDate(displayDate, lang);
const readingMinutes = estimateReadingTime(post.content);
const readingLabel =
  lang === 'es' ? `${readingMinutes} min de lectura` : `${readingMinutes} min read`;

const coverAlt =
  lang === 'es'
    ? `Imagen destacada del artículo del blog Slowork: ${cardTitle}`
    : `Featured image for this Slowork blog article: ${cardTitle}`;
---

<a
  href={postUrl}
  aria-label={cardTitle}
  class="group flex h-full min-h-0 w-full min-w-0 flex-1 flex-col overflow-hidden rounded-3xl bg-light-green text-left no-underline shadow-md border border-primary/10 transition-all duration-300 ease-out hover:-translate-y-1.5 hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-bg-landing touch-manipulation"
>
  {/*
    Caja de ratio fija + imagen en absolute: el tamaño intrínseco del remoto no puede reventar la altura de la tarjeta.
  */}
  <div class="relative aspect-video w-full shrink-0 overflow-hidden bg-primary/5">
    {cloudFrontImage ? (
      <Image
        src={cloudFrontImage}
        alt={coverAlt}
        width={1280}
        height={720}
        format="webp"
        loading={imageLcpPriority ? 'eager' : 'lazy'}
        fetchpriority={imageLcpPriority ? 'high' : 'auto'}
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
    ) : post.image_url ? (
      <img
        src={post.image_url}
        alt={coverAlt}
        loading={imageLcpPriority ? 'eager' : 'lazy'}
        fetchpriority={imageLcpPriority ? 'high' : 'auto'}
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
    ) : (
      <div class="absolute inset-0" aria-hidden="true" />
    )}
  </div>

  <div class="flex min-h-0 min-w-0 flex-1 flex-col p-5 sm:p-6">
    <!-- Meta: fecha + tiempo de lectura -->
    <div class="mb-2.5 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-primary/60">
      <time datetime={displayDate} class="capitalize">{formattedDate}</time>
      <span aria-hidden="true" class="text-primary/30">·</span>
      <span>{readingLabel}</span>
    </div>

    <h2 class="mb-3 font-heading text-xl font-bold leading-snug text-primary line-clamp-2 sm:text-2xl">
      {cardTitle}
    </h2>

    {/*
      line-clamp no aplica bien a HTML con <p>/<hr>/<img>; max-height + overflow + márgenes a cero evitan huecos gigantes.
    */}
    {post.excerpt ? (
      <div
        class="mb-4 min-h-0 max-h-21 w-full min-w-0 overflow-hidden text-sm leading-relaxed text-primary/80 [&_a]:font-medium [&_a]:text-primary [&_a]:no-underline [&_blockquote]:my-0 [&_div]:my-0 [&_h1]:my-0 [&_h2]:my-0 [&_h3]:my-0 [&_h4]:my-0 [&_hr]:hidden [&_img]:hidden [&_li]:my-0 [&_ol]:my-0 [&_p]:my-0 [&_pre]:my-0 [&_ul]:my-0"
        set:html={stripH1TagsFromHtml(post.excerpt)}
      />
    ) : (
      <div
        class="mb-4 min-h-0 max-h-21 w-full min-w-0 overflow-hidden text-sm leading-relaxed text-primary/80 [&_a]:font-medium [&_a]:text-primary [&_a]:no-underline [&_blockquote]:my-0 [&_div]:my-0 [&_h1]:my-0 [&_h2]:my-0 [&_h3]:my-0 [&_h4]:my-0 [&_hr]:hidden [&_img]:hidden [&_li]:my-0 [&_ol]:my-0 [&_p]:my-0 [&_pre]:my-0 [&_ul]:my-0"
        set:html={stripH1TagsFromHtml(post.content)}
      />
    )}

    <span class="mt-auto inline-flex items-center gap-2 pt-1 text-sm font-bold text-primary transition-colors duration-300 group-hover:text-secondary sm:text-base">
      {cta}
      <!-- Flecha con animación de desplazamiento horizontal al hover -->
      <span
        class="inline-block transition-transform duration-300 ease-out group-hover:translate-x-1.5"
        aria-hidden="true"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </span>
    </span>
  </div>
</a>
