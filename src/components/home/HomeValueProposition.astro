---
import type { SupportedLang } from '@/lib/seo';
import { HOME_CAROUSEL, homeValueCopy } from '@/lib/homeContent';

interface Props {
  lang: SupportedLang;
}

const { lang } = Astro.props;
const copy = homeValueCopy(lang);
---

<section
  class="home-value-bleed relative z-0 -mt-24 max-sm:-mt-16 min-h-screen w-full rounded-t-[35px] border-t border-primary/12 bg-bg-landing bg-linear-to-b from-light-green to-bg-landing pb-20 pt-14"
>
  <div class="mx-auto max-w-7xl px-6">
    <h2
      class="home-reveal text-center font-heading text-3xl font-bold text-primary sm:text-4xl md:text-6xl"
      data-home-reveal
    >
      {copy.title}
    </h2>
    <p
      class="home-reveal mx-auto mt-6 max-w-3xl text-center text-lg text-primary/85 sm:text-xl"
      data-home-reveal
      data-reveal-delay="120"
    >
      {copy.subtitle}
    </p>

    <div class="my-12 flex flex-col-reverse items-center justify-center gap-10 lg:flex-row lg:gap-16">
      <div
        class="home-reveal w-full max-w-xl rounded-3xl border border-primary/10 border-t-light-green/60 bg-light-green/80 p-6 shadow-lg shadow-primary/15 backdrop-blur-xl transition-transform duration-300 hover:scale-[1.02] sm:p-8 lg:p-10"
        data-home-reveal
        data-reveal-delay="220"
      >
        <h3
          class="my-6 text-center font-heading text-2xl font-semibold leading-tight text-primary sm:text-3xl lg:text-4xl"
        >
          {copy.cardLead1}
          <span class="font-bold text-soft-blue">{copy.cardLead2}</span>{copy.cardLead3}
        </h3>
        <p class="mb-6 text-center text-base leading-relaxed text-primary/85 sm:text-lg lg:text-xl">
          {copy.phrase1}
        </p>
        <p class="text-center text-base leading-relaxed text-primary/85 sm:text-lg lg:text-xl">
          {copy.phrase2a}<strong>{copy.phrase2b}</strong>
        </p>
      </div>

      <div
        class="home-reveal group relative mx-auto w-full max-w-sm shrink-0 lg:max-w-none lg:w-[30vw]"
        data-home-reveal
        data-reveal-delay="360"
      >
        <div
          id="image-carousel"
          class="relative aspect-square cursor-grab select-none overflow-hidden rounded-[11rem] border border-primary/10 shadow-xl shadow-primary/25 active:cursor-grabbing"
        >
          <img
            data-carousel-img
            src={HOME_CAROUSEL[0].src.src}
            alt={HOME_CAROUSEL[0].alt[lang]}
            width={HOME_CAROUSEL[0].src.width}
            height={HOME_CAROUSEL[0].src.height}
            sizes="(max-width: 1023px) min(100vw, 24rem), 30vw"
            class="h-full w-full object-cover opacity-100 scale-100 transition-[opacity,transform] duration-700 ease-in-out will-change-[opacity,transform]"
            loading="eager"
            fetchpriority="low"
            decoding="async"
          />
          <button
            type="button"
            id="carousel-prev"
            class="absolute left-2 top-1/2 z-10 hidden -translate-y-1/2 rounded-full bg-primary/55 p-2 text-secondary opacity-0 transition-opacity hover:bg-primary/70 group-hover:opacity-100 sm:grid sm:place-items-center"
            aria-label={lang === 'es' ? 'Anterior' : 'Previous'}
          >
            <span class="text-lg leading-none" aria-hidden="true">‹</span>
          </button>
          <button
            type="button"
            id="carousel-next"
            class="absolute right-2 top-1/2 z-10 hidden -translate-y-1/2 rounded-full bg-primary/55 p-2 text-secondary opacity-0 transition-opacity hover:bg-primary/70 group-hover:opacity-100 sm:grid sm:place-items-center"
            aria-label={lang === 'es' ? 'Siguiente' : 'Next'}
          >
            <span class="text-lg leading-none" aria-hidden="true">›</span>
          </button>
        </div>
        <div id="carousel-dots" class="mt-4 flex justify-center gap-2">
          {
            HOME_CAROUSEL.map((_, idx) => (
              <button
                type="button"
                class:list={['carousel-dot h-2.5 w-2.5 rounded-full transition-all', idx === 0 ? 'bg-primary scale-110' : 'bg-primary/35 hover:bg-primary/55']}
                data-carousel-dot
                data-idx={idx}
                aria-label={lang === 'es' ? `Ir a imagen ${idx + 1}` : `Go to slide ${idx + 1}`}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ HOME_CAROUSEL, lang }}>
  (() => {
    const track = document.getElementById('image-carousel');
    if (!track) return;

    HOME_CAROUSEL.forEach((slide) => {
      const link = document.createElement('link');
      link.rel = 'preload';
      link.as = 'image';
      link.href = slide.src.src;
      document.head.appendChild(link);
    });

    const carouselImg = track.querySelector('[data-carousel-img]');
    const dots = () => Array.from(document.querySelectorAll('.carousel-dot'));

    const state = { idx: 0, dragging: false, startX: 0 };
    const timers = { auto: undefined };
    let applyGeneration = 0;
    let fadeOutController = null;
    let fadeSwapTimeoutId = undefined;

    const imagePath = (u) => {
      try {
        return new URL(u, window.location.href).pathname;
      } catch {
        return u;
      }
    };

    const apply = () => {
      const n = HOME_CAROUSEL.length;
      if (!n) return;
      state.idx = ((state.idx % n) + n) % n;
      const slide = HOME_CAROUSEL[state.idx];
      const myGen = (applyGeneration += 1);

      dots().forEach((d, i) => {
        const on = i === state.idx;
        d.classList.toggle('bg-primary', on);
        d.classList.toggle('scale-110', on);
        d.classList.toggle('bg-primary/35', !on);
        d.classList.toggle('hover:bg-primary/55', !on);
      });

      if (!(carouselImg instanceof HTMLImageElement) || !slide) return;

      const nextSrc = slide.src.src;
      const nextAlt = slide.alt[lang];
      const curPath = imagePath(carouselImg.currentSrc || carouselImg.src);
      if (curPath === imagePath(nextSrc)) {
        carouselImg.classList.remove('opacity-0', 'scale-105');
        carouselImg.classList.add('opacity-100', 'scale-100');
        return;
      }

      fadeOutController?.abort();
      fadeOutController = null;
      if (fadeSwapTimeoutId !== undefined) {
        window.clearTimeout(fadeSwapTimeoutId);
        fadeSwapTimeoutId = undefined;
      }
      carouselImg.onload = null;
      carouselImg.onerror = null;

      const showImage = () => {
        if (myGen !== applyGeneration) return;
        carouselImg.classList.add('scale-105');
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            if (myGen !== applyGeneration) return;
            carouselImg.classList.remove('opacity-0', 'scale-105');
            carouselImg.classList.add('opacity-100', 'scale-100');
          });
        });
      };

      const finishSwap = () => {
        if (myGen !== applyGeneration) return;
        carouselImg.onload = null;
        carouselImg.onerror = null;
        carouselImg.src = nextSrc;
        carouselImg.alt = nextAlt;

        const afterReady = () => {
          if (typeof carouselImg.decode === 'function') {
            carouselImg
              .decode()
              .then(showImage)
              .catch(showImage);
            return;
          }
          showImage();
        };

        if (carouselImg.complete) afterReady();
        else {
          carouselImg.onload = afterReady;
          carouselImg.onerror = afterReady;
        }
      };

      carouselImg.classList.remove('opacity-100', 'scale-105');
      carouselImg.classList.add('opacity-0', 'scale-100');

      let fadeOutDone = false;
      const runSwapAfterFadeOut = () => {
        if (fadeOutDone || myGen !== applyGeneration) return;
        fadeOutDone = true;
        if (fadeSwapTimeoutId !== undefined) {
          window.clearTimeout(fadeSwapTimeoutId);
          fadeSwapTimeoutId = undefined;
        }
        fadeOutController?.abort();
        fadeOutController = null;
        finishSwap();
      };

      const onFadeOut = (e) => {
        if (e.propertyName !== 'opacity') return;
        runSwapAfterFadeOut();
      };

      fadeOutController = new AbortController();
      carouselImg.addEventListener('transitionend', onFadeOut, {
        signal: fadeOutController.signal,
      });
      fadeSwapTimeoutId = window.setTimeout(runSwapAfterFadeOut, 780);
    };

    const startAuto = () => {
      timers.auto = window.setInterval(() => {
        state.idx += 1;
        apply();
      }, 4500);
    };

    const stopAuto = () => {
      if (timers.auto !== undefined) clearInterval(timers.auto);
      timers.auto = undefined;
    };

    document.getElementById('carousel-prev')?.addEventListener('click', () => {
      state.idx -= 1;
      apply();
    });
    document.getElementById('carousel-next')?.addEventListener('click', () => {
      state.idx += 1;
      apply();
    });
    dots().forEach((d) =>
      d.addEventListener('click', () => {
        state.idx = Number(d.getAttribute('data-idx') ?? '0');
        apply();
      }),
    );

    track.addEventListener('mousedown', (e) => {
      state.dragging = true;
      state.startX = e.clientX;
    });
    window.addEventListener('mouseup', (e) => {
      if (!state.dragging) return;
      state.dragging = false;
      const d = state.startX - e.clientX;
      if (Math.abs(d) > 50) {
        state.idx += d > 0 ? 1 : -1;
        apply();
      }
    });

    startAuto();
    track.addEventListener('mouseenter', stopAuto);
    track.addEventListener('mouseleave', () => {
      stopAuto();
      startAuto();
    });

    apply();
  })();
</script>

<style>
  /* Cristal sobre degradado vertical landing (sin tintes azulados). */
  .home-value-bleed {
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
  }
</style>
