---
import Button from '@/components/ui/Button.astro';
import type { SupportedLang } from '@/lib/seo';
import { homeFinalCtaCopy } from '@/lib/homeContent';

interface Props {
  lang: SupportedLang;
}

const { lang } = Astro.props;
const copy = homeFinalCtaCopy(lang);
---

<section
  id="waitlist-cta"
  class="home-final-cta-bleed relative z-0 -mt-20 max-sm:-mt-16 rounded-t-[40px] border-t border-primary/12 bg-bg-landing bg-linear-to-b from-light-green to-bg-landing py-14 md:py-20"
>
  <div
    class="home-reveal reveal-depth mx-auto flex max-w-4xl flex-col items-center px-4 text-center"
    data-home-reveal
  >
    <h2 class="font-heading text-3xl font-bold tracking-tight text-primary text-balance md:text-5xl">
      {copy.title}
    </h2>
    <div class="mt-10 flex justify-center">
      <Button
        variant="primary"
        type="button"
        openWaitlist
        class="px-8 py-3.5 shadow-xl md:min-h-14 md:px-10 md:text-lg"
      >
        {copy.waitlist}
      </Button>
    </div>
  </div>
</section>

<style>
  .home-final-cta-bleed {
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
  }
</style>
