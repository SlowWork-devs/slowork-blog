---
import { Image } from 'astro:assets';
import carouselHost from '../../assets/images/carousel-host.jpg';
import carouselJungle from '../../assets/images/carousel-jungle.jpg';
import type { SupportedLang } from '../../lib/seo';
import type { ImpactProgramContent } from '../../models/legal';

interface Props {
  impact: ImpactProgramContent;
  lang: SupportedLang;
}

const { impact, lang } = Astro.props;
const homeHref = `/${lang}/`;
---

<section class="relative overflow-hidden rounded-3xl border border-secondary/40 bg-white/80 shadow-lg shadow-primary/10">
  <div class="relative min-h-[70vh] md:min-h-[80vh]">
    <Image
      src={carouselJungle}
      alt=""
      width={1920}
      height={1080}
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-primary/85 via-primary/70 to-primary/55"></div>
    <div class="relative z-10 flex min-h-[70vh] flex-col items-center justify-center px-6 py-24 text-center text-white md:min-h-[80vh]">
      <h1 class="font-heading text-4xl font-extrabold tracking-wide text-secondary sm:text-5xl md:text-6xl">
        {impact.hero.title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-white/90 sm:text-xl">{impact.hero.subtitle}</p>
    </div>
  </div>

  <div class="border-t border-secondary/50 bg-gradient-to-br from-light-green/40 to-bg-landing px-4 py-14 sm:px-8">
    <div class="prose mx-auto max-w-3xl text-justify">
      <h2>{impact.story.title}</h2>
      <p class="italic">{impact.story.paragraph1}</p>
      <p>{impact.story.paragraph2}</p>
    </div>
  </div>

  <div class="border-t border-secondary/50 bg-gradient-to-br from-bg-landing to-light-green/30 px-4 py-14 sm:px-8">
    <div class="prose mx-auto max-w-3xl text-justify">
      <h2>{impact.mission.title}</h2>
      <p class="italic">{impact.mission.paragraph1}</p>
      <p>{impact.mission.paragraph2}</p>
      <blockquote class="not-prose rounded-xl border-l-4 border-primary bg-white/70 p-6 text-primary/90 shadow-sm">
        {impact.mission.paragraph3}
      </blockquote>
    </div>
  </div>

  <div class="border-t border-secondary/50 bg-white/60 px-4 py-14 sm:px-8">
    <h2 class="text-center font-heading text-3xl font-bold text-primary sm:text-4xl">{impact.howItWorks.title}</h2>
    <ul class="mx-auto mt-10 grid max-w-5xl gap-4 sm:grid-cols-2">
      {impact.howItWorks.items.map((item) => (
        <li class="flex gap-3 rounded-xl border border-primary/10 bg-white/80 p-5 text-primary/90 shadow-sm">
          <span class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-secondary/25 font-bold text-primary" aria-hidden="true">→</span>
          <span class="leading-relaxed">{item}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="border-t border-secondary/50 bg-gradient-to-br from-light-green/25 to-bg-landing px-4 py-14 sm:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="font-heading text-3xl font-bold text-primary sm:text-4xl">{impact.whatWeSupport.title}</h2>
      <p class="mt-4 text-lg text-primary/85">{impact.whatWeSupport.subtitle}</p>
      <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {impact.whatWeSupport.items.map((item) => (
          <li class="rounded-xl border border-primary/10 bg-white/85 p-6 text-center font-medium text-primary shadow-sm">
            <span class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-full bg-secondary/30 text-primary" aria-hidden="true">✓</span>
            <p class="leading-snug">{item}</p>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-secondary/50 bg-bg-landing px-4 py-14 sm:px-8">
    <div class="prose mx-auto max-w-3xl text-center">
      <h2>{impact.whyItMatters.title}</h2>
      <blockquote class="not-prose rounded-2xl border-l-4 border-primary bg-white/80 p-8 text-lg italic text-primary/90 shadow-md">
        {impact.whyItMatters.paragraph}
      </blockquote>
    </div>
  </div>

  <div class="relative overflow-hidden rounded-b-3xl border-t border-secondary/50">
    <Image
      src={carouselHost}
      alt=""
      width={1920}
      height={900}
      class="absolute inset-0 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-primary/70"></div>
    <div class="relative z-10 px-6 py-16 text-center text-white sm:py-20">
      <h2 class="font-heading text-3xl font-extrabold text-secondary sm:text-4xl">{impact.cta.title}</h2>
      <p class="mx-auto mt-4 max-w-xl text-white/90">{impact.cta.subtitle}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href={homeHref}
          class="inline-flex min-h-12 items-center justify-center rounded-full bg-secondary px-8 py-3 font-bold text-primary shadow-lg transition hover:opacity-95"
        >
          {lang === 'es' ? 'Volver a inicio' : 'Back to home'}
        </a>
        <a
          href={`${homeHref}#waitlist-cta`}
          class="inline-flex min-h-12 items-center justify-center rounded-full border-2 border-secondary/80 bg-white/10 px-8 py-3 font-bold text-secondary backdrop-blur transition hover:bg-white/15"
        >
          {lang === 'es' ? 'Unirme a la waitlist' : 'Join the waitlist'}
        </a>
      </div>
    </div>
  </div>
</section>
