---
/**
 * Contenedor común para textos legislativos: fondo gris azulado suave y documento en tarjeta blanca centrada.
 */
---

<main
  class="legal-doc-page w-full bg-slate-200 px-4 pb-24 pt-28 sm:px-6 md:pb-28 md:pt-32"
>
  <div
    class="legal-doc-shell mx-auto w-full max-w-3xl rounded-lg bg-white px-6 py-10 shadow-[0_4px_24px_rgba(15,23,42,0.08)] sm:px-10 sm:py-12"
  >
    <slot />
  </div>
</main>
