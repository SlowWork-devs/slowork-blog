---
export const prerender = false;

import { getCollection, render } from 'astro:content';
import BlogPost from '@/layouts/BlogPost.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getBlogById, getBlogBySlug, type ApiLang } from '@/lib/api-service';
import { Image } from 'astro:assets';
import BlogArticleBackButton from '@/components/ui/BlogArticleBackButton.astro';
import { formatBlogCreationDate, htmlToPlainText, estimateReadingTime, wrapFirstH2Section } from '@/lib/blog-display';
import ScrollToTopButton from '@/components/ui/ScrollToTopButton.astro';
import type { SupportedLang } from '@/lib/seo';
import { BLOG_IMAGE_CLOUDFRONT_HOST, SITE_DESCRIPTION } from '@/consts';

const langParam = Astro.params.lang;
const slugParam = Astro.params.slug ?? '';

if (langParam !== 'es' && langParam !== 'en') {
  return Astro.redirect('/en/', 302);
}

const lang = langParam as ApiLang;
const allPosts = await getCollection('blog');

const mdEntry = allPosts.find((entry) => {
  const segments = entry.id.split('/');
  const fileSlug = segments[segments.length - 1]?.replace(/\.(md|mdx)$/, '') ?? '';
  const entryLang = entry.data.language ?? segments[0];
  return entryLang === lang && fileSlug === slugParam;
});

type RenderContent = Awaited<ReturnType<typeof render>>['Content'];
let MdContent: RenderContent | null = null;

if (mdEntry) {
  const rendered = await render(mdEntry);
  MdContent = rendered.Content;
}

let apiPost: Awaited<ReturnType<typeof getBlogById>> | null = null;

if (!mdEntry) {
  try {
    apiPost = /^\d+$/.test(slugParam)
      ? await getBlogById({ id: Number.parseInt(slugParam, 10), lang })
      : await getBlogBySlug({ slug: slugParam, lang });
  } catch {
    return new Response(null, { status: 404, statusText: 'Not Found' });
  }
}

if (!mdEntry && apiPost === null) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const blogLang: SupportedLang = lang === 'en' ? 'en' : 'es';

const apiEsPath =
  lang === 'es' ? Astro.url.pathname : apiPost ? `/es/blog/${apiPost.slug}/` : '/es/blog/';
const apiEnPath =
  lang === 'en' ? Astro.url.pathname : apiPost ? `/en/blog/${apiPost.slug}/` : '/en/blog/';
const apiEsHref = new URL(apiEsPath, Astro.url.origin).href;
const apiEnHref = new URL(apiEnPath, Astro.url.origin).href;
const apiXDefaultHref = lang === 'es' ? apiEsHref : apiPost ? apiEsHref : apiEnHref;

const apiExcerptPlain =
  apiPost && apiPost.excerpt.trim().length > 0
    ? htmlToPlainText(apiPost.excerpt)
    : '';
const apiMetaDescription =
  apiExcerptPlain.length > 0 ? apiExcerptPlain : SITE_DESCRIPTION;

const apiDisplayDate = apiPost ? apiPost.date_published || apiPost.creation_date : '';
const apiFormattedDate = apiPost ? formatBlogCreationDate(apiDisplayDate, lang) : '';
const apiCreationDatetimeIso = apiPost ? new Date(apiDisplayDate).toISOString() : '';
const apiReadingMinutes = apiPost ? estimateReadingTime(apiPost.content) : 0;
const apiReadingLabel = apiPost
  ? lang === 'es'
    ? `${apiReadingMinutes} min de lectura`
    : `${apiReadingMinutes} min read`
  : '';
const apiCategoryLabel = apiPost?.category
  ? lang === 'es'
    ? apiPost.category.name_es
    : apiPost.category.name_en
  : null;
const apiProcessedContent = apiPost ? wrapFirstH2Section(apiPost.content) : '';

const apiSocialImage =
  apiPost?.image_url && /^https?:\/\//i.test(apiPost.image_url) ? apiPost.image_url : undefined;
const apiCfHero =
  apiSocialImage &&
  (() => {
    try {
      return new URL(apiSocialImage).hostname === BLOG_IMAGE_CLOUDFRONT_HOST ? apiSocialImage : null;
    } catch {
      return null;
    }
  })();
---

{
  mdEntry && MdContent ? (
    <BlogPost {...mdEntry.data}>
      <MdContent />
    </BlogPost>
  ) : apiPost ? (
    <MainLayout
      lang={lang}
      title={apiPost.title}
      description={apiMetaDescription}
      ogType="article"
      keywords={apiPost.keywords ?? []}
      socialImage={apiSocialImage}
      alternates={[
        { hreflang: 'es', href: apiEsHref },
        { hreflang: 'en', href: apiEnHref },
        { hreflang: 'x-default', href: apiXDefaultHref },
      ]}
    >
      {apiSocialImage ? (
        <link
          slot="head"
          rel="preload"
          as="image"
          href={apiSocialImage}
          fetchpriority="high"
        />
      ) : null}

      <main class="w-full max-w-7xl mx-auto px-6 pt-32 pb-10 sm:pt-32 sm:pb-14 md:py-24">
        <article>
          <div class="w-full overflow-hidden rounded-2xl mb-8 md:mb-12">
            {apiCfHero ? (
              <Image
                src={apiCfHero}
                alt={apiPost.title}
                inferSize
                fetchpriority="high"
                loading="eager"
                class="w-full h-auto object-cover aspect-2/1"
              />
            ) : apiSocialImage ? (
              <img
                src={apiSocialImage}
                alt={apiPost.title}
                width={1020}
                height={510}
                fetchpriority="high"
                loading="eager"
                class="w-full h-auto object-cover aspect-2/1"
              />
            ) : null}
          </div>
          <div class="prose-container max-w-3xl mx-auto w-full">
            <div class="mb-10 flex justify-start">
              <BlogArticleBackButton lang={blogLang} />
            </div>
            <header class="mb-10 md:mb-14">
              <!-- Ceja tipográfica: categoría + tiempo de lectura -->
              <div class="mb-4 flex flex-wrap items-center gap-x-3 gap-y-2">
                {apiCategoryLabel && (
                  <span class="rounded-full bg-secondary/15 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-secondary">
                    {apiCategoryLabel}
                  </span>
                )}
                {apiReadingLabel && (
                  <span class="text-xs font-medium uppercase tracking-widest text-primary/50">
                    {apiReadingLabel}
                  </span>
                )}
              </div>
              <h1 class="font-heading font-bold text-primary text-4xl md:text-5xl leading-[1.1] tracking-tight mb-5">
                {apiPost.title}
              </h1>
              <!-- Fecha sutil -->
              <time
                datetime={apiCreationDatetimeIso}
                class="block text-sm font-light text-primary/50 capitalize"
              >
                {apiFormattedDate}
              </time>
              <div class="mt-6 h-px w-full bg-linear-to-r from-secondary/40 via-primary/10 to-transparent" />
            </header>
            <div
              class="prose prose-lg max-w-none w-full text-primary/90 selection:bg-secondary/30 prose-headings:font-heading prose-headings:text-primary prose-h2:mt-16 prose-h2:border-l-4 prose-h2:border-secondary prose-h2:pl-4 prose-h2:text-2xl prose-h2:font-bold prose-h2:leading-tight prose-h3:mt-10 prose-h3:text-xl prose-h3:font-semibold prose-p:leading-relaxed prose-a:text-soft-blue prose-a:font-bold prose-a:no-underline prose-a:transition-colors prose-a:hover:text-primary prose-img:rounded-3xl prose-img:border-4 prose-img:border-light-green/50 prose-img:shadow-2xl prose-blockquote:border-l-[6px] prose-blockquote:border-l-secondary prose-blockquote:bg-light-green/20 prose-blockquote:px-8 prose-blockquote:py-4 prose-blockquote:rounded-r-2xl prose-blockquote:italic prose-blockquote:text-primary/80 prose-li:marker:font-bold prose-li:marker:text-secondary prose-hr:my-12 prose-hr:border-primary/10"
              set:html={apiProcessedContent}
            />
          </div>
        </article>
      </main>

      <ScrollToTopButton lang={blogLang} />
    </MainLayout>
  ) : null
}
