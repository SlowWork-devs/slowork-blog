---
export const prerender = true;

export async function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

import { getImage } from 'astro:assets';

import MainLayout from '@/layouts/MainLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import FeaturedPost from '@/components/FeaturedPost.astro';
import { BLOG_IMAGE_CLOUDFRONT_HOST, SITE_TITLE } from '@/consts';
import { getBlogs } from '@/lib/api-service';

const lang = Astro.params.lang;
if (lang !== 'es' && lang !== 'en') {
  return Astro.redirect('/en/', 302);
}

const page = Number(Astro.url.searchParams.get('page') ?? '1') || 1;
const limit = Number(Astro.url.searchParams.get('limit') ?? '12') || 12;
const { items: posts } = await getBlogs({ page, limit, lang });

const firstPost = posts[0];
const remainingPosts = posts.slice(1);

let blogIndexLcpImageHref: string | null = null;
if (firstPost?.image_url && /^https?:\/\//i.test(firstPost.image_url)) {
  try {
    const imgUrl = new URL(firstPost.image_url);
    if (imgUrl.hostname === BLOG_IMAGE_CLOUDFRONT_HOST) {
      const optimized = await getImage({
        src: firstPost.image_url,
        width: 1280,
        height: 720,
        format: 'webp',
      });
      const src = optimized.src;
      blogIndexLcpImageHref = src.startsWith('http')
        ? src
        : new URL(src, Astro.site ?? Astro.url.origin).href;
    } else {
      blogIndexLcpImageHref = firstPost.image_url;
    }
  } catch {
    blogIndexLcpImageHref = firstPost.image_url;
  }
}

const esBlogIndex = new URL('/es/blog/', Astro.url.origin).href;
const enBlogIndex = new URL('/en/blog/', Astro.url.origin).href;

const blogMetaDescription =
  lang === 'es'
    ? `${SITE_TITLE} — Sitio oficial. Blog: guías y reflexiones para confirmar que otro estilo de vida es posible.`
    : `${SITE_TITLE} — Official site. Blog: guides and reflections on another way of life.`;

const heroTitle = lang === 'es' ? 'Blog' : 'Blog';
const heroSubtitle =
  lang === 'es'
    ? 'Rediseña tu mundo. Guías y reflexiones para confirmar que otro estilo de vida es posible.'
    : 'Redesign your world. Guides and reflections to confirm another way of life is possible.';
---

<MainLayout
  lang={lang}
  title={`${SITE_TITLE} | Blog`}
  description={blogMetaDescription}
  alternates={[
    { hreflang: 'es', href: esBlogIndex },
    { hreflang: 'en', href: enBlogIndex },
    { hreflang: 'x-default', href: esBlogIndex },
  ]}
>
  {blogIndexLcpImageHref ? (
    <link slot="head" rel="preload" as="image" href={blogIndexLcpImageHref} fetchpriority="high" />
  ) : null}

  <!-- Fondo sutil con degradado radial verde muy tenue -->
  <div
    class="pointer-events-none fixed inset-0 -z-10"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 80% 60% at 50% -10%, color-mix(in srgb, var(--color-secondary, #6c9a6c) 8%, transparent) 0%, transparent 70%);"
  />

  <main class="w-full max-w-7xl mx-auto px-6 pt-32 pb-10 sm:pt-32 sm:pb-14 md:py-24">

    <!-- Header editorial -->
    <header class="text-center mb-14 sm:mb-18 md:mb-22 animate-fade-in-down">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.25em] text-secondary/80">
        {lang === 'es' ? 'Reflexiones & Guías' : 'Reflections & Guides'}
      </p>
      <h1 class="font-heading font-bold text-primary mb-5 text-[clamp(2.25rem,6vw+1rem,4.5rem)] leading-[1.1] tracking-tight">
        {heroTitle}
      </h1>
      <div class="w-20 h-1 bg-secondary mx-auto rounded-full mb-6 md:mb-8" />
      <p class="text-primary/70 max-w-xl mx-auto leading-relaxed text-base sm:text-lg md:text-xl font-light italic">
        {heroSubtitle}
      </p>
    </header>

    <!-- Hero post (primer artículo) -->
    {firstPost && (
      <section class="mb-10 sm:mb-14 md:mb-16 animate-fade-in-down" aria-label={lang === 'es' ? 'Artículo destacado' : 'Featured article'}>
        <FeaturedPost post={firstPost} lang={lang} />
      </section>
    )}

    <!-- Grid de posts restantes (2 columnas) -->
    {remainingPosts.length > 0 && (
      <section aria-label={lang === 'es' ? 'Más artículos' : 'More articles'}>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 list-none p-0">
          {remainingPosts.map((post) => (
            <li class="flex h-full min-h-0 min-w-0 w-full flex-col">
              <BlogCard post={post} lang={lang} imageLcpPriority={false} />
            </li>
          ))}
        </ul>
      </section>
    )}

  </main>
</MainLayout>
