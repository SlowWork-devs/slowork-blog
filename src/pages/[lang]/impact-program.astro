---
import MainLayout from '../../layouts/MainLayout.astro';
import ImpactProgramArticle from '../../components/legal/ImpactProgramArticle.astro';
import { buildI18nAlternates } from '../../lib/hreflang';
import { getLegalBundle } from '../../lib/legalBundle';
import type { SupportedLang } from '../../lib/seo';

const lang = Astro.params.lang as SupportedLang;
if (lang !== 'es' && lang !== 'en') return Astro.redirect('/en/', 302);

const bundle = getLegalBundle(lang);
const impact = bundle.impactProgram;
const { alternates, headerAlternateLink } = buildI18nAlternates(Astro.url.origin, '/impact-program/', lang);

const title = impact.helmet.title;
const description = impact.helmet.description;
---

<MainLayout
  lang={lang}
  title={title}
  description={description}
  canonical={`/${lang}/impact-program/`}
  headerAlternateLink={headerAlternateLink}
  alternates={alternates}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: impact.hero.title,
    description,
    url: new URL(`/${lang}/impact-program/`, Astro.url.origin).href,
  }}
>
  <main class="mx-auto w-full max-w-6xl px-4 pb-16 pt-28 sm:px-6 md:py-24">
    <ImpactProgramArticle impact={impact} lang={lang} />
  </main>
</MainLayout>
